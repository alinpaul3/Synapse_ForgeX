# Database
DATABASE_URL=postgresql://user:password@localhost:5432/synapse_forgex

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# YouTube OAuth
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

# Reddit OAuth
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:8000/api/auth/reddit/callback
REDDIT_USER_AGENT=SynapseForgeX/1.0

# ML Pipeline
ML_PIPELINE_URL=http://localhost:8001/predict

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["chrome-extension://*","http://localhost:3000","http://localhost:5173"]

# Encryption key for sensitive data (32 bytes base64)
ENCRYPTION_KEY=your-32-byte-encryption-key-base64=
